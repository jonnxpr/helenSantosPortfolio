{
  "name": "helen-santos-ritual-site",
  "version": "1.0.0",
  "description": "Single page therapeutic massage site for Helen Santos with i18n, responsive design, and GitHub Pages CI/CD",
  "author": "Helen Santos",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonnxpr/helenSantosPortfolio.git"
  },
  "keywords": [
    "helen-santos",
    "massagem-relaxante-terapeutica",
    "thai-massagem",
    "bambu-terapia",
    "responsive",
    "i18n",
    "github-pages",
    "html5",
    "css3",
    "javascript"
  ],
  "scripts": {
    "start": "node scripts/start-static.mjs",
    "start:localhost": "node scripts/start-static.mjs --host localhost",
    "start:127": "node scripts/start-static.mjs --host 127.0.0.1",
    "start:all": "node scripts/start-static.mjs --host 0.0.0.0",
    "verify:metadata": "node scripts/verify-metadata-sync.mjs",
    "prepare:pages": "node scripts/prepare-pages-artifact.mjs",
    "verify:metadata:artifact": "node scripts/verify-metadata-sync.mjs --root .pages-artifact --label Pages-artifact-metadata",
    "build:css": "cleancss css/styles.css -o css/styles.min.css",
    "watch:css": "chokidar \"css/styles.css\" --initial -c \"npm run build:css\"",
    "build:js": "terser js/navigation.js js/i18n.js js/animations.js js/site-shell.js js/hero.js js/experience-flow.js js/rituals.js js/pillars.js js/main.js -o js/main.min.js -c -m",
    "build": "npm run verify:metadata && npm run build:css && npm run build:js"
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "clean-css-cli": "^5.6.1",
    "terser": "^5.16.0"
  }
}
